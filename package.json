{
  "name": "memai",
  "version": "0.1.0",
  "description": "MemAI: Your personal digital memory bank and AI assistant",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:client dev:python",
    "dev:client": "vite",
    "dev:python": "./.venv/bin/uvicorn server.main:app --reload --port 3000",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier -w '**/*.{js,jsx,ts,tsx}'"
  },
  "keywords": [
    "ai",
    "chatbot",
    "gemini",
    "react",
    "typescript",
    "memory"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "superagent": "^10.2.2"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.12.2",
    "@tanstack/react-query-devtools": "^5.13.3",
    "@types/node": "^20.17.17",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/superagent": "^8.1.1",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
